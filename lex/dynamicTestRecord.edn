{:lexicon 1
 :id "com.etzhayyim.yamabiko.dynamicTestRecord"
 :defs
 {:main
  {:type "record"
   :key  "tid"
   :record
   {:type       "object"
    :required   ["tid" "speedProfile" "brakingDistance" "powerDraw" "emergencyStop" "thermalSignature"]
    :properties {:tid              {:type "string" :description "Transaction ID"}
                 :speedProfile     {:type "string" :description "Speed ramp-up trajectory and max speed achieved (≤320 km/h per G12)"}
                 :brakingDistance  {:type "string" :description "Emergency and service braking distance from max speed"}
                 :powerDraw        {:type "string" :description "Measured power draw under load (kW)"}
                 :emergencyStop    {:type "string" :description "Emergency stop response time and procedure compliance"}
                 :thermalSignature {:type "string" :description "Motor and electrical system thermal imaging results"}}}}}}

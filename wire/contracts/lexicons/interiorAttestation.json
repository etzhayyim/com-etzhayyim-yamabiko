{
  "lexicon" : 1,
  "id" : "com.etzhayyim.yamabiko.interiorAttestation",
  "description" : "Interior + HVAC + PIS attestation (L3). Al-honeycomb floor + fire-retardant seating + wheelchair accessibility + HEPA HVAC + multilingual PIS. G5 trilingual + N6 anti-advertising + N8 anti-face-recognition + N10 anti-luxury-only. Per ADR-2605252600 L3.",
  "defs" : {
    "main" : {
      "type" : "record",
      "record" : {
        "type" : "object",
        "properties" : {
          "trainsetId" : {
            "type" : "string"
          },
          "carIndex" : {
            "type" : "integer"
          },
          "floor" : {
            "type" : "unknown"
          },
          "seating" : {
            "type" : "unknown"
          },
          "accessibility" : {
            "type" : "unknown"
          },
          "hvac" : {
            "type" : "unknown"
          },
          "pisConfig" : {
            "type" : "object",
            "properties" : {
              "languages" : {
                "type" : "array",
                "items" : {
                  "type" : "string"
                },
                "minItems" : 3
              },
              "g5Trilingual" : {
                "type" : "boolean",
                "const" : true
              },
              "n6AdvertisingPresent" : {
                "type" : "boolean",
                "const" : false
              },
              "n8FaceRecognitionPresent" : {
                "type" : "boolean",
                "const" : false
              },
              "accept" : {
                "type" : "boolean",
                "const" : true
              }
            },
            "required" : [ "g5Trilingual", "n6AdvertisingPresent", "n8FaceRecognitionPresent", "accept" ]
          },
          "recordedAt" : {
            "type" : "string",
            "format" : "datetime"
          }
        },
        "required" : [ "trainsetId", "carIndex", "pisConfig" ]
      }
    }
  }
}

{
  "lexicon": 1,
  "id": "com.etzhayyim.yamabiko.silenRailReview",
  "description": "Council 5-of-7 Safe attestation review for every new Wave / new trainset class / new jurisdiction / G7 propulsion transition / gate amendment. Per ADR-2605252600 Council Lv6+ supermajority for any G/N amendment.",
  "defs": {
    "main": {
      "type": "record",
      "record": {
        "type": "object",
        "properties": {
          "reviewSubjectId": {"type": "string"},
          "scope": {
            "type": "string",
            "knownValues": [
              "r0-scaffold-baseline",
              "r1-benchtop-mockup",
              "r2-pilot-trainset",
              "r3-community-scale",
              "wave-1-shinkansen-class",
              "wave-2-conventional-rail",
              "wave-3-lrt-tram",
              "g7-propulsion-transition-r1-to-r2",
              "robot-class-activation-tsugite",
              "robot-class-activation-wadasa",
              "robot-class-activation-toritsuke",
              "robot-class-activation-pantagora",
              "non-goal-amendment-goa4",
              "gate-amendment-G12-speed-revision",
              "new-jurisdiction-homologation"
            ]
          },
          "councilSafeAddress": {"type": "string"},
          "councilSignatures": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "councilMemberDid": {"type": "string", "format": "did"},
                "signature": {"type": "string"},
                "timestamp": {"type": "string", "format": "datetime"}
              }
            },
            "minItems": 5
          },
          "decision": {"type": "string", "knownValues": ["approve", "reject", "request-revision"]},
          "rationale": {"type": "string"},
          "recordedAt": {"type": "string", "format": "datetime"}
        },
        "required": ["reviewSubjectId", "scope", "councilSignatures", "decision", "recordedAt"]
      }
    }
  }
}

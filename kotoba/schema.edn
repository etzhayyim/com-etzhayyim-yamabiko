;; yamabiko 山彦 — kotoba EAVT schema
;; ADR-2605252600 · R0 scaffold
;; High-speed rail trainset manufacturing: 9-cell 5-layer assembly workflow + 2 cross-cutting cells
;; All state kotoba Datoms (no RisingWave/Cypher canonical; G16)

[;; ───────────────────────────── :trainset/* — per-trainset registry entry ─────────────────────────────
 {:db/ident :trainset/did
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "Per-trainset DID (did:web:etzhayyim.com:yamabiko:trainset:<serial>; G13)"}
 {:db/ident :trainset/serial-number
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "Trainset serial number (manufacturer identifier)"}
 {:db/ident :trainset/car-count
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "Car count (8-16 per Wave 1)"}
 {:db/ident :trainset/max-speed-kmh
  :db/valueType :db.type/long
  :db/cardinality :db.cardinality/one
  :db/doc "Max certified speed (≤320 km/h per G12)"}


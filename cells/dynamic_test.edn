                    :writes   []}
 :cell/state-graph {:nodes [{:id "start" :type "llm-prompt" :prompt "Collect dynamic test telemetry: speed profile, braking distance, power draw, emergency stop response, thermal signature."}
                           {:id "validate" :type "function" :func "validate_dynamic_test"}
                           {:id "record" :type "function" :func "record_dynamic_test_record"}
                           {:id "end" :type "return"}]
                    :entry    "start"
                    :edges    [{:from "start" :to "validate"}
                               {:from "validate" :to "record"}
                               {:from "record" :to "end"}]}}

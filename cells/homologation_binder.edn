;; yamabiko 山彦 — homologation_binder cell (L5c)
{:cell/id          "homologation_binder"
 :cell/glyph       "📋"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "L5c homologation: aggregate ISO 3095 noise + IEC 62236 EMC + 騒音規制法 attestations; bind per-trainset DID (G13); emit trainsetManufactureRecord."
 :cell/gates       [{:gate/id "G8"  :gate/name "noise-emc-compliance"}
                    {:gate/id "G13" :gate/name "trainset-did-per-serial"}
                    {:gate/id "G14" :gate/name "eol-recyclability"}]
 :cell/llm         {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/kotoba      {:reads    []
                    :writes   []}
 :cell/state-graph {:nodes [{:id "start" :type "llm-prompt" :prompt "Collect homologation attestations: ISO 3095 noise cert, IEC 62236 EMC cert, 騒音規制法 compliance, EoL recyclability audit."}
                           {:id "validate" :type "function" :func "validate_homologation"}
                           {:id "mint-did" :type "function" :func "mint_trainset_did"}
                           {:id "record" :type "function" :func "record_homologation"}
                           {:id "end" :type "return"}]
                    :entry    "start"
                    :edges    [{:from "start" :to "validate"}
                               {:from "validate" :to "mint-did"}
                               {:from "mint-did" :to "record"}
                               {:from "record" :to "end"}]}}
